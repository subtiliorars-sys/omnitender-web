#!/usr/bin/env bash
#
# Portable pre-commit secret scanner (agent-corps git-guards kit).
# Blocks any commit whose staged ADDED lines contain credentials (GitHub tokens,
# Google / OpenAI keys, private keys). Universal — safe in every repo.
#
# Bypass intentionally (rare, e.g. a documented example token): git commit --no-verify
#
set -uo pipefail

# Things that must never be committed.
SECRET_PATTERNS='github_pat_[A-Za-z0-9_]{20,}|ghp_[A-Za-z0-9]{30,}|gho_[A-Za-z0-9]{30,}|ghs_[A-Za-z0-9]{30,}|AIza[0-9A-Za-z_-]{30,}|sk-[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|-----BEGIN[A-Z ]*PRIVATE KEY-----'

# Only inspect lines being ADDED (ignore +++ headers and context).
added_lines="$(git diff --cached --diff-filter=ACM -U0 | grep '^+' | grep -v '^+++' || true)"
hits="$(printf '%s\n' "$added_lines" | grep -E "$SECRET_PATTERNS" || true)"

if [ -n "$hits" ]; then
  echo ""
  echo "🚫  COMMIT BLOCKED — a possible secret was found in your staged changes:"
  echo ""
  printf '%s\n' "$hits" | sed -E 's/(github_pat_|ghp_|gho_|ghs_|AIza|sk-|xox[baprs]-)[A-Za-z0-9_-]+/\1***REDACTED***/g'
  echo ""
  echo "Remove the secret (or unstage that file) and commit again."
  echo "If you are 100% sure this is a false positive: git commit --no-verify"
  echo ""
  exit 1
fi
# Run documentation/HTML validation check.
if [ -f "./check_web_links.py" ]; then
  echo "🔍  Validating HTML references and accessibility..."
  python3 ./check_web_links.py
  if [ $? -ne 0 ]; then
    echo "🚫  COMMIT BLOCKED — HTML reference or validation check failed. Fix the broken links and try again."
    exit 1
  fi
fi

exit 0
