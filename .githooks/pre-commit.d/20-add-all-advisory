#!/usr/bin/env bash
#
# pre-commit.d/20-add-all-advisory — ADVISORY, NON-BLOCKING (agent-corps git-guards).
# S-8: parallel instances share clones, so a `git add -A` / `git add .` /
# `git commit -a` can sweep up another instance's WIP (this really happened —
# ~300 lines lost to a sibling `git reset --hard`). git exposes no `add` hook and
# pre-commit can't see the command used, so this uses the staging SHAPE as a proxy:
#   * many staged files at once, and/or
#   * newly-added (untracked-then-staged) files — the signature of `add -A`/`add .`
#     (`commit -a` never stages new files).
# It only WARNS and always exits 0; the commit proceeds. Tune the trip point with
# GG_ADDALL_THRESHOLD (default 12).
#
set -uo pipefail

threshold="${GG_ADDALL_THRESHOLD:-12}"

n="$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | wc -l | tr -d ' ')"
[ "${n:-0}" -gt 0 ] || exit 0
added_new="$(git diff --cached --name-only --diff-filter=A 2>/dev/null | wc -l | tr -d ' ')"

if [ "$n" -ge "$threshold" ] || [ "$added_new" -ge "$threshold" ]; then
  cat >&2 <<MSG

⚠️  [git-guards S-8 advisory] This commit stages $n file(s) ($added_new newly added) —
    the shape of a bulk 'git add -A' / 'git add .' / 'git commit -a'.
    Parallel AI instances share clones: stage ONLY files you changed this session
    (use 'safe-commit <branch> <msg> <file>...'). Unexplained files? Leave them.
    This is ADVISORY ONLY — the commit will proceed. Silence: GG_ADDALL_THRESHOLD=999

MSG
fi
exit 0
