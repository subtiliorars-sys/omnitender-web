# Supabase connection settings — names only, NO real values.
# These are sourced from GitHub Actions secrets at deploy time (see
# .github/workflows/deploy.yml) and rendered into config.js for the
# browser. Do not put real values in this file or commit a real .env.

# Project API URL — not secret, safe in the browser.
SUPABASE_URL=

# Publishable (anon) key — not secret, safe in the browser.
# Supabase Row Level Security policies are what actually protect data.
SUPABASE_PUBLISHABLE_KEY=

# Service role / secret key — SERVER-SIDE ONLY.
# Must NEVER be embedded in any browser-served file (config.js, HTML, JS
# bundles) and must NEVER be committed as a literal value anywhere in this
# repo. This static site has no server component, so this var should only
# ever be consumed by the separate backend (omnitender-omniverse on Fly.io),
# not by anything here.
SUPABASE_SECRET_KEY=
